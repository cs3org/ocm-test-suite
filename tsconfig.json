{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["bun", "cypress"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["cypress/**/*.ts", "scripts/typescript/**/*.ts"]
}
