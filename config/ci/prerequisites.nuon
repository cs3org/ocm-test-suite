{
    # Each rule here declares that a given capability must pass before listed flows can run.
    # This is a CI-level gate separate from the per-flow required_capabilities in config/matrix/flows/.
    "capability_rules": [
        {
            # op.login is the shared login operation required by multi-step flows
            # listed in required_for_flows below.
            "capability_flow": "login",
            "required_for_flows": [
                "share-with",
                "contact-token",
                "contact-wayf"
            ],
            "required_roles": [
                "sender",
                "receiver"
            ]
        }
    ]
}
