      "v34"
    ],
    "ocis": [
      "v8"
    ],
    "opencloud": [
      "v6"
    ]
  },
  "versions_receiver": {
    "nextcloud": [
      "v34"
    ],
    "ocis": [
      "v8"
    ],
    "opencloud": [
      "v6"
    ]
  }
}