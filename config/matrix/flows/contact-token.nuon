{
  "schema_version": 1,
  "flow_id": "contact-token",
  "two_party": true,
  "enabled": true,
  "mitm": true,
  "browsers": null,
  "include": [
    {
      "sender": [
        "nextcloud",
        "ocis",
        "opencloud"
